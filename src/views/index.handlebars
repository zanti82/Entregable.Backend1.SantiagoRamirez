<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos</title>
    <style>
        .productos-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            padding: 20px;
        }
        .producto-card {
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 15px;
            background: white;
        }
        .producto-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }
        .precio {
            font-weight: bold;
            color: green;
        }
        .sin-imagen {
            width: 100%;
            height: 200px;
            background: #eee;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .acciones {
            margin-top: 10px;
        }
        button {
            padding: 5px 10px;
            margin-right: 5px;
            cursor: pointer;
        }
    </style>
</head>
<body>

<h1>Lista de productos</h1>

<div class="productos-container">
    {{#each products}}
    <div class="producto-card">

        {{#if this.thumbnails}}
            <img src="/uploads/{{this.thumbnails}}" alt="{{this.title}}">
        {{else}}
            <div class="sin-imagen">Sin imagen</div>
        {{/if}}

        <h3>{{this.title}}</h3>
        <p>{{this.description}}</p>
        <p class="precio">${{this.price}}</p>
        <p>Stock: {{this.stock}}</p>
        <p>Categoría: {{this.category}}</p>

        <div class="acciones">
            <a href="/products/{{this._id}}">
                <button>Ver detalle</button>
            </a>

            <button onclick="addToCart('{{this._id}}')">
                Agregar al carrito
            </button>
        </div>

    </div>
    {{/each}}
</div>

<!-- PAGINACIÓN -->
<div style="text-align:center; margin:20px;">
    
    {{#if hasPrevPage}}
        <a href="/products?page={{prevPage}}">Anterior</a>
    {{/if}}

    <span>Página {{page}} de {{totalPages}}</span>

    {{#if hasNextPage}}
        <a href="/products?page={{nextPage}}">Siguiente</a>
    {{/if}}

</div>

<script>
function addToCart(pid) {
    const cartId = "ID_DEL_CARRITO"; // reemplazar

    fetch(`/api/carts/${cartId}/products/${pid}`, {
        method: "POST"
    })
    .then(res => res.json())
    .then(data => console.log(data))
    .catch(err => console.log(err));
}
</script>

</body>
</html>