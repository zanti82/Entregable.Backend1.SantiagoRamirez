<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalle del producto</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin: auto;
            border: 1px solid #ddd;
            padding: 20px;
            border-radius: 8px;
        }

        img {
            width: 100%;
            height: 300px;
            object-fit: cover;
        }

        .sin-imagen {
            width: 100%;
            height: 300px;
            background: #eee;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .precio {
            font-size: 1.5em;
            color: green;
            font-weight: bold;
        }

        button {
            padding: 10px;
            margin-top: 10px;
            cursor: pointer;
        }

        a {
            display: inline-block;
            margin-top: 15px;
        }
    </style>
</head>

<body>

<div class="container">

    {{#if product.thumbnails}}
        <img src="/uploads/{{product.thumbnails}}" alt="{{product.title}}">
    {{else}}
        <div class="sin-imagen">Sin imagen</div>
    {{/if}}

    <h1>{{product.title}}</h1>

    <p>{{product.description}}</p>

    <p class="precio">$ {{product.price}}</p>

    <p>Stock: {{product.stock}}</p>

    <p>Categoría: {{product.category}}</p>

    <button onclick="addToCart('{{product._id}}')">
        Agregar al carrito
    </button>

    <br>

    <a href="/products">← Volver a productos</a>

</div>

<script>
function addToCart(pid) {
    const cartId = "TU_CART_ID"; // ← reemplaza esto

    fetch(`/api/carts/${cartId}/products/${pid}`, {
        method: "POST"
    })
    .then(res => res.json())
    .then(data => {
        console.log("Producto agregado:", data);
        alert("Producto agregado al carrito");
    })
    .catch(err => console.log(err));
}
</script>

</body>
</html>